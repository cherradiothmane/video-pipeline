# ─── Whisper (Speech-to-Text) ─────────────────────────────────────────────────
WHISPER_MODEL=large-v3          # tiny, base, small, medium, large-v2, large-v3
WHISPER_DEVICE=cuda             # cuda or cpu
WHISPER_COMPUTE_TYPE=float16    # float16 (GPU), int8_float16 (less VRAM), int8 (CPU)

# ─── Ollama (LLM) ────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b        # or: mistral-small3.1:24b, llama3.1:8b, etc.
LLM_LANGUAGE=fr                 # Language for generated summaries/titles

# ─── OCR ─────────────────────────────────────────────────────────────────────
OCR_ENABLED=true
OCR_LANGUAGES=fr,en             # Comma-separated language codes
OCR_FPS_SAMPLE=1.0              # Frames per second to analyze (1.0 = 1 frame/sec)
OCR_MIN_CONFIDENCE=0.5          # Minimum OCR confidence threshold

# ─── Storage ─────────────────────────────────────────────────────────────────
OUTPUT_DIR=./outputs
UPLOAD_DIR=./uploads

# ─── Queue (Celery) ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
